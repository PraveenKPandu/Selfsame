<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>dev.selfsame</groupId>
  <artifactId>selfsame</artifactId>
  <version>0.1.0-alpha</version>
  <packaging>jar</packaging>

  <name>selfsame</name>
  <description>Sound behavior-equivalence verification for the JVM (Selfsame Protocol implementation)</description>
  <url>https://github.com/PraveenKPandu/Selfsame</url>

  <licenses>
    <license><name>MIT</name></license>
  </licenses>

  <properties>
    <maven.compiler.release>17</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <bytebuddy.version>1.14.19</bytebuddy.version>
  </properties>

  <!--
    The comparator core (Canonical/Soundness/Json/ValueCodec) and the replay
    worker are pure JDK. ByteBuddy is needed ONLY by the capture agent
    (dev.selfsame.agent.*); it is shaded into the single output jar so a consumer
    adds NO dependency to their own build (the agent jar is self-contained, like
    the OpenTelemetry/Datadog Java agents). The conformance core also builds with
    plain javac (no Maven), see README.
  -->
  <dependencies>
    <dependency>
      <groupId>net.bytebuddy</groupId>
      <artifactId>byte-buddy</artifactId>
      <version>${bytebuddy.version}</version>
    </dependency>
  </dependencies>

  <build>
    <finalName>selfsame</finalName>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.5.3</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals><goal>shade</goal></goals>
            <configuration>
              <transformers>
                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                  <manifestEntries>
                    <Premain-Class>dev.selfsame.agent.Agent</Premain-Class>
                    <Can-Retransform-Classes>true</Can-Retransform-Classes>
                    <Main-Class>dev.selfsame.Cli</Main-Class>
                  </manifestEntries>
                </transformer>
              </transformers>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
